<header
  class="fixed w-full z-50 bg-white/90 backdrop-blur-md shadow-sm border-b border-slate-100 dark:border-slate-800"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      <div class="flex-shrink-0 flex items-center gap-2">
        <span
          class="font-display font-bold text-2xl text-medical-blue tracking-tight"
          >Oral<span class="text-primary">ProFace</span></span
        >
      </div>
      <nav class="hidden md:flex space-x-8">
        <a
          class="text-slate-700 hover:text-primary font-medium transition-colors"
          href="#">Inicio</a
        >
        <a
          class="text-slate-700 hover:text-primary font-medium transition-colors"
          href="#nosotros">Nosotros</a
        >
        <a
          class="text-slate-700 hover:text-primary font-medium transition-colors"
          href="#servicios">Servicios</a
        >
        <a
          class="text-slate-700 hover:text-primary font-medium transition-colors"
          href="#testimonios">Testimonios</a
        >
      </nav>
      <div class="hidden md:flex items-center">
        <a
          class="bg-primary hover:bg-lime text-white hover:text-medical-blue px-6 py-2.5 font-medium transition-all shadow-md hover:shadow-lg transform hover:-translate-y-0.5 flex items-center gap-2"
          href="#contacto"
        >
          <span>Agendar cita</span>
          <span class="material-icons-outlined text-sm">calendar_today</span>
        </a>
      </div>
      <div class="md:hidden flex items-center">
        <button
          class="text-slate-600 dark:text-slate-200 hover:text-primary p-2"
        >
          <span class="material-icons text-3xl">menu</span>
        </button>
      </div>
    </div>
  </div>
</header>
