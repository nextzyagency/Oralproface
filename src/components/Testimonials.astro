---
const b = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<section class="py-24 bg-medical-gray overflow-hidden" id="testimonios">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="text-primary text-sm font-bold tracking-wider uppercase"
        >Historias de Transformación</span
      >
      <h2
        class="font-display text-3xl md:text-5xl lg:text-6xl font-bold text-medical-blue mt-2"
      >
        Vidas que Cambiaron por Completo
      </h2>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
      <!-- Card 1 -->
      <div class="flex flex-col h-[80vh] group">
        <div
          class="relative flex-1 overflow-hidden shadow-2xl border-4 border-white bg-white"
        >
          <!-- After (Default) -->
          <img
            src={`${b}/imagenes/testimonials/testimonial-1-despues.jpg`}
            alt="Paciente 1 - Resultados Finales"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          />

          <!-- Before (Reveal on hover) -->
          <div
            class="absolute inset-0 w-full h-full overflow-hidden opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-10 pointer-events-none"
          >
            <img
              src={`${b}/imagenes/testimonials/testimonial-1-antes.jpg`}
              alt="Paciente 1 - Estado Inicial"
              class="absolute inset-0 w-full h-full object-cover grayscale-[0.5]"
            />
            <div class="absolute inset-0 bg-medical-blue/20"></div>
          </div>

          <!-- Label -->
          <div class="absolute bottom-6 right-6 z-20">
            <span
              class="inline-flex items-center gap-2 px-6 py-2 bg-lime text-medical-blue font-bold uppercase tracking-widest text-xs shadow-lg group-hover:bg-primary group-hover:text-white transition-colors duration-300"
            >
              <span class="material-icons text-sm">visibility</span>
            </span>
          </div>
        </div>

        <div class="mt-8 space-y-3">
          <div class="flex items-center justify-between">
            <h3
              class="text-2xl font-bold text-medical-blue uppercase tracking-tight"
            >
              María González
            </h3>
            <div class="flex text-lime">
              <span class="material-icons text-sm">star</span>
              <span class="material-icons text-sm">star</span>
              <span class="material-icons text-sm">star</span>
              <span class="material-icons text-sm">star</span>
              <span class="material-icons text-sm">star</span>
            </div>
          </div>
          <p class="text-neutral-gray text-lg leading-relaxed italic">
            "Llevaba años usando dentadura postiza y sufriendo para comer. El
            equipo de Oral ProFace me devolvió la confianza en solo 3 días."
          </p>
          <p class="text-primary font-bold text-sm uppercase tracking-widest">
            Tratamiento: Implantología Basal
          </p>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="flex flex-col h-[80vh] group">
        <div
          class="relative flex-1 overflow-hidden shadow-2xl border-4 border-white bg-white"
        >
          <!-- After (Default) -->
          <img
            src={`${b}/imagenes/testimonials/testimonial-2-despues.jpg`}
            alt="Paciente 2 - Resultados Finales"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          />

          <!-- Before (Reveal on hover) -->
          <div
            class="absolute inset-0 w-full h-full overflow-hidden opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-10 pointer-events-none"
          >
            <img
              src={`${b}/imagenes/testimonials/testimonial-2-antes.jpg`}
              alt="Paciente 2 - Estado Inicial"
              class="absolute inset-0 w-full h-full object-cover grayscale-[0.5]"
            />
            <div class="absolute inset-0 bg-medical-blue/20"></div>
          </div>

          <!-- Label -->
          <div class="absolute bottom-6 right-6 z-20">
            <span
              class="inline-flex items-center gap-2 px-6 py-2 bg-lime text-medical-blue font-bold uppercase tracking-widest text-xs shadow-lg group-hover:bg-primary group-hover:text-white transition-colors duration-300"
            >
              <span class="material-icons text-sm">visibility</span>
            </span>
          </div>
        </div>

        <div class="mt-8 space-y-3">
          <div class="flex items-center justify-between">
            <h3
              class="text-2xl font-bold text-medical-blue uppercase tracking-tight"
            >
              Roberto Díaz
            </h3>
            <div class="flex text-lime">
              <span class="material-icons text-sm">star</span>
              <span class="material-icons text-sm">star</span>
              <span class="material-icons text-sm">star</span>
              <span class="material-icons text-sm">star</span>
              <span class="material-icons text-sm">star</span>
            </div>
          </div>
          <p class="text-neutral-gray text-lg leading-relaxed italic">
            "La atención fue increíble desde el primer momento. El resultado fue
            exactamente como me lo mostraron en la planificación digital."
          </p>
          <p class="text-primary font-bold text-sm uppercase tracking-widest">
            Tratamiento: Rehabilitación Estratégica
          </p>
        </div>
      </div>
    </div>

    <!-- Final CTA -->
    <div class="text-center mt-20">
      <a
        class="inline-flex items-center gap-4 bg-medical-blue text-white px-10 py-5 font-bold uppercase tracking-widest text-sm shadow-2xl hover:bg-primary transition-all duration-300 border-2 border-transparent hover:border-lime"
        href="#contacto"
      >
        <span>Transforma tu sonrisa hoy</span>
        <span class="material-icons">arrow_forward</span>
      </a>
    </div>
  </div>
</section>

<style>
  /* Optional: Smooth transition for scaling if not handled by Tailwind */
  .group:hover img {
    transform: scale(1.05);
  }
</style>
