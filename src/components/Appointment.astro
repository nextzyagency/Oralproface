---

<section class="py-20 bg-medical-gray">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2
        class="font-display text-3xl font-bold text-medical-blue"
      >
        Agende ahora su cita de valoración
      </h2>
      <p class="mt-3 text-slate-600 text-lg">
        Da el primer paso hacia tu nueva sonrisa hoy mismo.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
      <div
        class="bg-white p-8 shadow-sm border border-slate-200 flex flex-col items-center text-center transition-transform hover:-translate-y-1 hover:border-lime"
      >
        <div
          class="w-16 h-16 bg-medical-gray flex items-center justify-center text-primary mb-4"
        >
          <span class="material-icons text-3xl">videocam</span>
        </div>
        <h3 class="font-bold text-xl text-medical-blue mb-2">
          Cita de valoración online
        </h3>
        <p
          class="text-slate-600 text-sm mb-6 px-4 font-medium"
        >
          Accede a nuestro servicio de valoración preliminar desde la comodidad
          de tu hogar en cualquier parte del mundo.
        </p>
        <a
          class="w-full bg-primary hover:bg-lime hover:text-medical-blue text-white font-medium py-3 transition-colors flex justify-center items-center gap-2"
          href="#"
        >
          Agenda su cita online
          <span class="material-icons text-sm">logout</span>
        </a>
      </div>
      <div
        class="bg-white p-8 shadow-sm border border-slate-200 flex flex-col items-center text-center transition-transform hover:-translate-y-1 hover:border-lime"
      >
        <div
          class="w-16 h-16 bg-medical-gray flex items-center justify-center text-primary mb-4"
        >
          <span class="material-icons text-3xl">person_pin_circle</span>
        </div>
        <h3 class="font-bold text-xl text-medical-blue mb-2">
          Cita de valoración presencial
        </h3>
        <p
          class="text-slate-600 text-sm mb-6 px-4 font-medium"
        >
          Visita nuestras instalaciones de última generación para un diagnóstico
          completo con tomografía 3D.
        </p>
        <a
          class="w-full bg-primary hover:bg-lime hover:text-medical-blue text-white font-medium py-3 transition-colors flex justify-center items-center gap-2"
          href="#"
        >
          Agenda su cita presencial
          <span class="material-icons text-sm">person</span>
        </a>
      </div>
    </div>
  </div>
</section>
