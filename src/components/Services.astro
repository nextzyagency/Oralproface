---

---

<section class="py-20 bg-white" id="servicios">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="text-primary font-bold tracking-wider uppercase text-sm"
        >Nuestros Tratamientos</span
      >
      <h2
        class="mt-2 font-display text-3xl md:text-4xl font-bold text-medical-blue"
      >
        Excelencia en cada procedimiento
      </h2>
      <p class="mt-4 text-slate-600 text-lg">
        Soluciones integrales diseñadas para durar toda la vida.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <div
        class="group bg-white p-8 shadow-sm border border-gray-100 hover:shadow-xl hover:border-lime transition-all duration-300 overflow-hidden"
      >
        <div
          class="w-14 h-14 bg-medical-gray flex items-center justify-center text-primary mb-6 group-hover:scale-110 transition-transform"
        >
          <span class="material-icons text-3xl">biotech</span>
        </div>
        <h3
          class="font-display font-bold text-lg text-medical-blue mb-3"
        >
          Implantes Estratégicos Basales
        </h3>
        <p
          class="text-sm text-slate-600 leading-relaxed font-medium"
        >
          Fijación en hueso cortical profundo para máxima estabilidad, ideal
          para casos de atrofia severa.
        </p>
      </div>
      <div
        class="group bg-white p-8 shadow-sm border border-gray-100 hover:shadow-xl hover:border-lime transition-all duration-300 overflow-hidden"
      >
        <div
          class="w-14 h-14 bg-medical-gray flex items-center justify-center text-primary mb-6 group-hover:scale-110 transition-transform"
        >
          <span class="material-icons text-3xl">timer</span>
        </div>
        <h3
          class="font-display font-bold text-lg text-medical-blue mb-3"
        >
          Carga Inmediata
        </h3>
        <p
          class="text-sm text-slate-600 leading-relaxed font-medium"
        >
          Dientes fijos en menos de 72 horas. Recupera tu sonrisa y función
          masticatoria rápidamente.
        </p>
      </div>
      <div
        class="group bg-white p-8 shadow-sm border border-gray-100 hover:shadow-xl hover:border-lime transition-all duration-300 overflow-hidden"
      >
        <div
          class="w-14 h-14 bg-medical-gray flex items-center justify-center text-primary mb-6 group-hover:scale-110 transition-transform"
        >
          <span class="material-icons text-3xl">medical_services</span>
        </div>
        <h3
          class="font-display font-bold text-lg text-medical-blue mb-3"
        >
          Rehabilitación Oral Completa
        </h3>
        <p
          class="text-sm text-slate-600 leading-relaxed font-medium"
        >
          Restauración total de la boca combinando estética y funcionalidad
          perfecta.
        </p>
      </div>
      <div
        class="group bg-white p-8 shadow-sm border border-gray-100 hover:shadow-xl hover:border-lime transition-all duration-300 overflow-hidden"
      >
        <div
          class="w-14 h-14 bg-medical-gray flex items-center justify-center text-primary mb-6 group-hover:scale-110 transition-transform"
        >
          <span class="material-icons text-3xl">auto_awesome</span>
        </div>
        <h3
          class="font-display font-bold text-lg text-medical-blue mb-3"
        >
          Diseño de Sonrisa Digital
        </h3>
        <p
          class="text-sm text-slate-600 leading-relaxed font-medium"
        >
          Visualiza tu nueva sonrisa antes de empezar con nuestra tecnología de
          escaneo 3D.
        </p>
      </div>
    </div>
    <div class="mt-12 text-center">
      <a
        class="inline-flex items-center text-primary font-semibold hover:text-medical-blue transition-colors"
        href="#contacto"
      >
        Ver todos los servicios
        <span class="material-icons ml-1 text-sm">arrow_forward</span>
      </a>
    </div>
  </div>
</section>
