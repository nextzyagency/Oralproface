---
const sedes = [
  {
    ciudad: "Barranquilla",
    direccion: "Cra.51B #94-334 Centro Médico Vital.",
    email: "oralproimplantes@gmail.com",
    tel: "57 310 3114580",
  },
  {
    ciudad: "Bogotá",
    direccion: "Clle. 93B #17- 42 Chico Norte Consultorio dental line.",
    email: "oralproimplantes@gmail.com",
    tel: "57 310 3114580",
  },
  {
    ciudad: "Maracaibo",
    direccion: "Clínica Dr. Carlos Alaimo IPS La Milagrosa Av 15 delicias.",
    email: "oralproimplantes.com",
    tel: "57 310 3114580",
  },
];
---

<div class="relative">
  <svg
    class="w-full h-16 text-medical-blue fill-current z-10 block"
    preserveAspectRatio="none"
    viewBox="0 0 1440 320"
  >
    <path
      d="M0,224L80,213.3C160,203,320,181,480,181.3C640,181,800,203,960,202.7C1120,203,1280,181,1360,170.7L1440,160L1440,320L1360,320C1280,320,1120,320,960,320C800,320,640,320,480,320C320,320,160,320,80,320L0,320Z"
      fill-opacity="1"></path>
  </svg>
</div>

<section class="bg-medical-blue pt-12 pb-20 px-4 sm:px-6 lg:px-8" id="contacto">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <div class="text-white">
        <h2 class="font-display text-3xl md:text-4xl font-bold mb-6 italic">
          Comunícate <br />con nosotros
        </h2>
        <p class="text-blue-100 mb-10 max-w-md">
          Estamos listos para atenderte y resolver todas tus dudas sobre
          nuestros tratamientos de implantología en cualquiera de nuestras
          sedes.
        </p>

        <div class="space-y-10">
          {
            sedes.map((sede) => (
              <div class="space-y-4 relative">
                <div class="flex items-center gap-3">
                  <span class="material-icons text-white text-2xl">
                    location_on
                  </span>
                  <h4 class="font-bold text-2xl tracking-tight">
                    {sede.ciudad}
                  </h4>
                </div>
                <div class="space-y-3 pl-9">
                  <div class="flex items-center gap-3 text-blue-100">
                    <span class="material-icons text-lime text-xl">email</span>
                    <span class="text-sm font-medium">oralproimplantes@gmail.com</span>
                  </div>
                  <div class="flex items-start gap-3 text-blue-100">
                    <span class="material-icons text-lime text-xl">map</span>
                    <span class="text-sm leading-snug">{sede.direccion}</span>
                  </div>
                  <div class="flex items-center gap-3 text-blue-100">
                    <span class="material-icons text-lime text-xl">phone</span>
                    <span class="text-sm font-medium">{sede.tel}</span>
                  </div>
                </div>
                <div class="absolute -bottom-5 left-9 right-0 h-px bg-white/10" />
              </div>
            ))
          }
        </div>
      </div>

      <div
        class="bg-white/5 backdrop-blur-sm p-8 border border-white/10 h-fit lg:sticky lg:top-24"
      >
        <h3 class="text-white font-bold text-xl mb-6 flex items-center gap-2">
          <span class="material-icons text-lime">send_to_mobile</span>
          Envíanos un mensaje
        </h3>
        <form id="contact-form" class="space-y-4">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label
                class="block text-sm font-medium text-blue-100 mb-1"
                for="nombre">Nombre</label
              >
              <input
                class="w-full bg-white/10 border border-white/20 px-4 py-2.5 text-white placeholder-blue-200/50 outline-none transition-all focus:border-lime"
                id="nombre"
                placeholder="Tu nombre"
                type="text"
                required
              />
            </div>
            <div>
              <label
                class="block text-sm font-medium text-blue-100 mb-1"
                for="apellidos">Apellidos</label
              >
              <input
                class="w-full bg-white/10 border border-white/20 px-4 py-2.5 text-white placeholder-blue-200/50 outline-none transition-all focus:border-lime"
                id="apellidos"
                placeholder="Tus apellidos"
                type="text"
                required
              />
            </div>
          </div>
          <div>
            <label
              class="block text-sm font-medium text-blue-100 mb-1"
              for="email">Correo Electrónico</label
            >
            <input
              class="w-full bg-white/10 border border-white/20 px-4 py-2.5 text-white placeholder-blue-200/50 outline-none transition-all focus:border-lime"
              id="email"
              placeholder="ejemplo@correo.com"
              type="email"
              required
            />
          </div>
          <div>
            <label
              class="block text-sm font-medium text-blue-100 mb-1"
              for="ciudad">Ciudad</label
            >
            <input
              class="w-full bg-white/10 border border-white/20 px-4 py-2.5 text-white placeholder-blue-200/50 outline-none transition-all focus:border-lime"
              id="ciudad"
              placeholder="Tu ciudad"
              type="text"
              required
            />
          </div>
          <div>
            <label
              class="block text-sm font-medium text-blue-100 mb-1"
              for="mensaje">Mensaje</label
            >
            <textarea
              class="w-full bg-white/10 border border-white/20 px-4 py-2.5 text-white placeholder-blue-200/50 outline-none transition-all focus:border-lime"
              id="mensaje"
              placeholder="¿En qué podemos ayudarte?"
              rows="6"
              required></textarea>
          </div>
          <div class="pt-4">
            <button
              class="w-full bg-lime hover:bg-primary text-medical-blue hover:text-white font-bold py-4 shadow-lg transition-all duration-300 uppercase tracking-widest text-sm"
              type="submit"
            >
              Contactar por WhatsApp
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  document.getElementById('contact-form')?.addEventListener('submit', function(e) {
    e.preventDefault();
    
    const nombre = document.getElementById('nombre').value;
    const apellidos = document.getElementById('apellidos').value;
    const email = document.getElementById('email').value;
    const ciudad = document.getElementById('ciudad').value;
    const mensaje = document.getElementById('mensaje').value;
    
    const message = `Hola Oralproface, mi nombre es ${nombre} ${apellidos}. Mi correo es ${email} y te escribo desde ${ciudad}. Mi mensaje: ${mensaje}`;
    const whatsappUrl = `https://wa.me/573008990189?text=${encodeURIComponent(message)}`;
    
    window.open(whatsappUrl, '_blank');
  });
</script>
