---

---

<div class="relative mt-20">
  <svg
    class="absolute top-0 w-full h-16 -mt-16 text-medical-blue fill-current z-10"
    preserveAspectRatio="none"
    viewBox="0 0 1440 320"
  >
    <path
      d="M0,224L80,213.3C160,203,320,181,480,181.3C640,181,800,203,960,202.7C1120,203,1280,181,1360,170.7L1440,160L1440,320L1360,320C1280,320,1120,320,960,320C800,320,640,320,480,320C320,320,160,320,80,320L0,320Z"
      fill-opacity="1"></path>
  </svg>
  <section
    class="bg-medical-blue pt-12 pb-20 px-4 sm:px-6 lg:px-8"
    id="contacto"
  >
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <div class="text-white">
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">
            Comunícate <br />con nosotros
          </h2>
          <p class="text-blue-100 mb-10 max-w-md">
            Estamos listos para atenderte y resolver todas tus dudas sobre
            nuestros tratamientos de implantología.
          </p>
          <div class="space-y-8">
            <div class="flex items-start gap-4">
              <div
                class="w-10 h-10 bg-white/10 flex items-center justify-center shrink-0"
              >
                <span class="material-icons text-lime">location_on</span>
              </div>
              <div>
                <h4 class="font-bold text-lg mb-1">Sede Principal</h4>
                <p class="text-blue-100 text-sm">
                  Av. Médica 123, Torre Elite, Piso 8.<br />Ciudad de México,
                  CDMX
                </p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div
                class="w-10 h-10 bg-white/10 flex items-center justify-center shrink-0"
              >
                <span class="material-icons text-lime">phone</span>
              </div>
              <div>
                <h4 class="font-bold text-lg mb-1">Teléfonos</h4>
                <p class="text-blue-100 text-sm mb-1">+52 (55) 1234 5678</p>
                <p class="text-blue-100 text-sm">+52 (55) 8765 4321</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div
                class="w-10 h-10 bg-white/10 flex items-center justify-center shrink-0"
              >
                <span class="material-icons text-lime">email</span>
              </div>
              <div>
                <h4 class="font-bold text-lg mb-1">Email</h4>
                <p class="text-blue-100 text-sm">contacto@oralproface.com</p>
                <p class="text-blue-100 text-sm">citas@oralproface.com</p>
              </div>
            </div>
          </div>
        </div>
        <div
          class="bg-white/5 backdrop-blur-sm p-8 border border-white/10"
        >
          <form class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label
                  class="block text-sm font-medium text-blue-100 mb-1"
                  for="nombre">Nombre</label
                >
                <input
                  class="w-full bg-white/10 border border-gray-300/30 px-4 py-2.5 text-white placeholder-blue-200/50 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all"
                  id="nombre"
                  placeholder="Tu nombre"
                  type="text"
                />
              </div>
              <div>
                <label
                  class="block text-sm font-medium text-blue-100 mb-1"
                  for="apellidos">Apellidos</label
                >
                <input
                  class="w-full bg-white/10 border border-gray-300/30 px-4 py-2.5 text-white placeholder-blue-200/50 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all"
                  id="apellidos"
                  placeholder="Tus apellidos"
                  type="text"
                />
              </div>
            </div>
            <div>
              <label
                class="block text-sm font-medium text-blue-100 mb-1"
                for="email">Correo Electrónico</label
              >
              <input
                class="w-full bg-white/10 border border-gray-300/30 rounded-lg px-4 py-2.5 text-white placeholder-blue-200/50 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all"
                id="email"
                placeholder="ejemplo@correo.com"
                type="email"
              />
            </div>
            <div>
              <label
                class="block text-sm font-medium text-blue-100 mb-1"
                for="ciudad">Ciudad</label
              >
              <input
                class="w-full bg-white/10 border border-gray-300/30 rounded-lg px-4 py-2.5 text-white placeholder-blue-200/50 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all"
                id="ciudad"
                placeholder="Tu ciudad"
                type="text"
              />
            </div>
            <div>
              <label
                class="block text-sm font-medium text-blue-100 mb-1"
                for="mensaje">Mensaje</label
              >
              <textarea
                class="w-full bg-white/10 border border-gray-300/30 px-4 py-2.5 text-white placeholder-blue-200/50 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all"
                id="mensaje"
                placeholder="¿En qué podemos ayudarte?"
                rows="4"></textarea>
            </div>
            <div class="pt-2">
              <button
                class="w-full bg-lime hover:bg-primary text-medical-blue hover:text-white font-bold py-3.5 shadow-lg hover:shadow-primary/30 transition-all duration-300 transform hover:-translate-y-1"
                type="submit"
              >
                Enviar ahora
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
</div>
