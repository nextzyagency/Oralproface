---
const heroImage = "/imagenes/hero/imagen2.jpg";
---

<section
  class="relative flex items-center bg-medical-gray overflow-hidden"
  id="inicio"
>
  <!-- Subtle background grid decoration -->
  <div
    class="absolute inset-0 opacity-[0.03]"
    style="background-image: linear-gradient(#0F4C81 1px, transparent 1px), linear-gradient(to right, #0F4C81 1px, transparent 1px); background-size: 48px 48px;"
  ></div>

  <div class="w-full max-w-7xl mx-auto px-5 sm:px-8 lg:px-12 xl:px-16 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8 items-center pt-28 pb-12 lg:pt-0 lg:pb-0 lg:min-h-screen">

      <!-- ───── LEFT: Copy — texto primero en móvil ───── -->
      <div class="flex flex-col justify-center space-y-5 order-1 lg:order-1">

        <!-- Badge -->
        <div class="flex items-center gap-2 w-fit">
          <span
            class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold tracking-widest uppercase border border-primary/20"
          >
            <span class="w-1.5 h-1.5 rounded-full bg-primary inline-block"></span>
            Precisión Digital
          </span>
        </div>

        <!-- H1 -->
        <h1
          class="font-display text-4xl sm:text-5xl lg:text-5xl xl:text-6xl font-bold text-slate-900 leading-[1.08] tracking-tight"
        >
          Recupera la<br />
          <span class="text-primary italic">Confianza</span> de<br />
          tu Sonrisa.
        </h1>

        <!-- Subtitle -->
        <p class="text-base lg:text-lg text-neutral-gray leading-relaxed max-w-lg">
          Implantología dental avanzada con enfoque humano. Restauramos
          más que dientes; restauramos tu capacidad de vivir sin límites.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3">
          <a
            href="https://wa.me/573103114580?text=Hola,%20deseo%20agendar%20una%20valoración%20de%20implantología."
            target="_blank"
            rel="noopener noreferrer"
            title="Agendar valoración de implantología en Oral ProFace"
            class="group inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-lime text-slate-900 font-bold text-sm tracking-wide rounded-full hover:bg-[#bae208] transition-all duration-300 shadow-lg shadow-lime/30 hover:shadow-lime/50"
          >
            <span class="material-icons text-base">calendar_month</span>
            Agendar Valoración
            <span class="material-icons text-base group-hover:translate-x-1 transition-transform duration-200">arrow_forward</span>
          </a>

          <a
            href="#testimonios"
            title="Ver resultados de tratamientos de implantología"
            class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-white text-slate-800 font-semibold text-sm tracking-wide rounded-full border border-slate-200 hover:border-primary hover:text-primary transition-all duration-300"
          >
            Ver Resultados
          </a>
        </div>

        <!-- Social proof strip -->
        <div class="flex items-center gap-5 pt-2 border-t border-slate-200">
          <div class="flex -space-x-2 shrink-0">
            <div class="w-8 h-8 rounded-full bg-primary flex items-center justify-center text-white text-xs font-bold border-2 border-white">M</div>
            <div class="w-8 h-8 rounded-full bg-medical-blue flex items-center justify-center text-white text-xs font-bold border-2 border-white">R</div>
            <div class="w-8 h-8 rounded-full bg-lime flex items-center justify-center text-slate-900 text-xs font-bold border-2 border-white">A</div>
            <div class="w-8 h-8 rounded-full bg-slate-700 flex items-center justify-center text-white text-xs font-bold border-2 border-white">+</div>
          </div>
          <div>
            <div class="flex items-center gap-0.5 text-lime">
              <span class="material-icons text-sm">star</span>
              <span class="material-icons text-sm">star</span>
              <span class="material-icons text-sm">star</span>
              <span class="material-icons text-sm">star</span>
              <span class="material-icons text-sm">star</span>
            </div>
            <p class="text-xs text-neutral-gray mt-0.5">
              <span class="font-bold text-slate-800">+30 pacientes</span> transformados con excelencia
            </p>
          </div>
        </div>
      </div>

      <!-- ───── RIGHT: Image — segundo en móvil ───── -->
      <div class="flex justify-center lg:justify-end items-center order-2 lg:order-2">
        <div class="relative w-full max-w-sm sm:max-w-md lg:max-w-full">

          <!-- Main image card -->
          <div
            class="relative overflow-hidden rounded-2xl lg:rounded-[2rem] shadow-2xl shadow-slate-300/60 aspect-[4/3] sm:aspect-[3/4] lg:aspect-[3/4] w-full"
          >
            <img
              src={heroImage}
              alt="Paciente con sonrisa perfecta tras implantología estratégica en Oral ProFace"
              title="Resultados reales de implantología dental en Oral ProFace"
              class="w-full h-full object-cover object-center"
              loading="eager"
              onerror="this.onerror=null; this.src='https://placehold.co/600x750/0F4C81/ffffff?text=Oral+ProFace';"
            />
            <!-- Colour overlay -->
            <div
              class="absolute inset-0 bg-gradient-to-b from-medical-blue/10 via-transparent to-medical-blue/40 pointer-events-none"
            ></div>
          </div>

          <!-- Floating stat card -->
          <div
            class="absolute -bottom-4 left-4 sm:-bottom-5 sm:-left-4 lg:-left-8 bg-white/95 backdrop-blur-md rounded-2xl px-4 py-3 shadow-xl shadow-slate-200/80 border border-slate-100 flex items-center gap-3"
          >
            <div class="shrink-0 w-9 h-9 rounded-full bg-lime/20 flex items-center justify-center">
              <span class="material-icons text-lime text-sm">verified_user</span>
            </div>
            <div>
              <p class="text-slate-900 font-bold text-sm leading-tight">+30 Casos Exitosos</p>
              <p class="text-neutral-gray text-xs mt-0.5">Excelencia clínica certificada</p>
            </div>
          </div>

          <!-- Accent decorations -->
          <div class="absolute -top-4 -right-4 w-16 h-16 rounded-full bg-lime/20 blur-2xl pointer-events-none"></div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>
