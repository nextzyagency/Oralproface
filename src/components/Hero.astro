---
const b = import.meta.env.BASE_URL.replace(/\/$/, "");
const heroImage = `${b}/imagenes/hero/imagen2.jpg`;
---

<section
  class="relative min-h-[85vh] flex items-center overflow-hidden bg-linear-to-r from-medical-blue via-primary to-cyan-500 pt-20 lg:pt-0"
>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-center">
      <!-- Left: Content -->
      <div class="order-1 lg:order-1 space-y-8 py-12">
        <div class="space-y-4">
          <span
            class="inline-block px-4 py-1.5 bg-white/10 text-white text-sm font-semibold tracking-wider uppercase border-l-4 border-lime backdrop-blur-sm"
          >
            Excelencia Odontológica
          </span>
          <h1
            class="text-4xl md:text-5xl lg:text-7xl font-bold text-white leading-tight uppercase tracking-tight"
          >
            Implantología <br />
            <span class="text-lime italic drop-shadow-sm">Estratégica</span>
          </h1>
          <p class="text-lg lg:text-xl text-white/90 leading-relaxed max-w-xl">
            Soluciones avanzadas para la pérdida dental severa. Recupera la
            función y la estética en tiempo récord con nuestros procedimientos
            mínimamente invasivos.
          </p>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          <a
            href="https://wa.me/573000000000?text=Hola,%20deseo%20agendar%20una%20valoración%20de%20implantología."
            target="_blank"
            class="group relative inline-flex items-center justify-center px-10 py-5 bg-white text-medical-blue font-bold rounded-none overflow-hidden transition-all duration-300 hover:bg-lime hover:text-medical-blue shadow-xl"
          >
            <span class="relative z-10 flex items-center gap-2">
              <span class="material-icons">calendar_month</span>
              Agendar valoración
            </span>
          </a>

          <a
            href="#servicios"
            class="inline-flex items-center justify-center px-10 py-5 border-2 border-white/50 text-white font-bold rounded-none transition-all duration-300 hover:border-white hover:bg-white/10"
          >
            Ver tratamientos
          </a>
        </div>
      </div>

      <!-- Right: Single Static Image (Smaller) -->
      <div class="order-2 lg:order-2 flex justify-center lg:justify-end py-12">
        <div
          class="relative w-full max-w-sm aspect-3/4 overflow-hidden rounded-none shadow-2xl border-4 border-white/20"
        >
          <img
            src={heroImage}
            alt="Implantología estratégica avanzada"
            class="w-full h-full object-cover transition-all duration-700"
            loading="eager"
            onerror="this.onerror=null; this.src='https://placehold.co/800x1000/0f4c81/ffffff?text=Imagen+No+Encontrada';"
          />

          <!-- Glossy overlay -->
          <div
            class="absolute inset-0 bg-linear-to-tr from-medical-blue/20 to-transparent pointer-events-none"
          >
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>
